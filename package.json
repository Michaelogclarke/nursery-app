{
  "name": "nursery-app",
  "version": "1.0.0",
  "description": "Nursery Management System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http-get://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "preview": "vite preview",
    "seed": "node -e \"const fs=require('fs'),{Pool}=require('pg'),cfg=JSON.parse(fs.readFileSync('db.config.json','utf-8'));new Pool({connectionString:cfg.connectionString}).query(fs.readFileSync('seed.sql','utf-8')).then(()=>{console.log('Seed complete.');process.exit(0)}).catch(e=>{console.error(e.message);process.exit(1)})\""  ,
    "setup": "node -e \"const fs=require('fs'),{Pool}=require('pg'),cfg=JSON.parse(fs.readFileSync('db.config.json','utf-8'));new Pool({connectionString:cfg.connectionString}).query(fs.readFileSync('setup.sql','utf-8')).then(()=>{console.log('Setup complete.');process.exit(0)}).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "teardown": "node -e \"const fs=require('fs'),{Pool}=require('pg'),cfg=JSON.parse(fs.readFileSync('db.config.json','utf-8'));new Pool({connectionString:cfg.connectionString}).query(fs.readFileSync('teardown.sql','utf-8')).then(()=>{console.log('Teardown complete.');process.exit(0)}).catch(e=>{console.error(e.message);process.exit(1)})\""
  },
  "build": {
    "appId": "com.nursery.manager",
    "productName": "Nursery Manager",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  }
}
